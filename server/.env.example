PORT=4000
MONGODB_URI=mongodb://localhost:27017/groww_ai
CLIENT_ORIGIN=http://localhost:5173
MARKET_DATA_PROVIDER=yahoo        # yahoo | groww | alphavantage | mock  (default yahoo: free, no key)
ALPHA_VANTAGE_API_KEY=            # required only if provider=alphavantage
# Groww auth — ONE of the following. The access token rotates daily ~6:00 AM IST.
GROWW_ACCESS_TOKEN=              # static token (dev): used verbatim; powers provider=groww + live orders (₹499/mo)
GROWW_API_KEY=                   # auto daily-token generation (POST /v1/token/api/access)
GROWW_API_SECRET=                # + secret → "approval" flow (SHA-256 checksum). Preferred for servers.
GROWW_TOTP_SECRET=               # OR a base32 TOTP secret → "totp" flow (used only if GROWW_API_SECRET is empty)
IGNORE_MARKET_HOURS=true          # true = auto-trading runs regardless of IST market hours
AUTO_TRADING_ENABLED=true

# --- REAL-MONEY (LIVE) TRADING — keep OFF unless you intend to place REAL orders ---
# Live AI trading requires ALL of: ENABLE_LIVE_TRADING=true, a Groww credential
# (token OR key+secret/TOTP), the user in 'live' mode, and ENABLE_LIVE_AUTO_TRADING=true.
# In live mode the AI uses the ENSEMBLE (Quant + Claude) and a real BUY needs BOTH
# models to agree. Live AUTO-EXIT is NOT automated (use the GTT stop-loss below or
# manage exits manually). Defaults below are deliberately conservative.
ENABLE_LIVE_TRADING=false         # master switch for live order placement via Groww (default OFF)
ENABLE_LIVE_AUTO_TRADING=false    # allow the AI auto-trading cron to place LIVE orders (default OFF — strongly recommended)
LIVE_MAX_ORDER_VALUE=5000         # hard ₹ cap per live BUY (blast-radius limit; applies to manual + auto)
LIVE_ARM_GTT_STOPLOSS=false       # opt-in: arm a native Groww GTT stop-loss after each live BUY (uses autoExit.stopLossPercent)

# --- AI MODEL (Claude LLM reasoning layer) ---
# The AI signal engine is an ensemble of a deterministic technical "Quant" model and
# a Claude LLM model. Without a key (or with AI_LLM_ENABLED=false) it falls back to
# the Quant model alone, so the app runs fully offline. The LLM is used only on the
# display paths (on-demand signal + dashboard top picks) and is cached; the 30s
# auto-trading cron always uses the fast Quant model.
ANTHROPIC_API_KEY=               # optional: enables the Claude model in the AI signal ensemble
AI_MODEL=claude-opus-4-8         # Claude model id used by the LLM signal model
AI_LLM_ENABLED=true              # master switch for the LLM model (no effect without ANTHROPIC_API_KEY)
