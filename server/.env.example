PORT=4000
MONGODB_URI=mongodb://localhost:27017/groww_ai
CLIENT_ORIGIN=http://localhost:5173
MARKET_DATA_PROVIDER=yahoo        # yahoo | groww | mock  (default yahoo: free, no key)
IGNORE_MARKET_HOURS=true          # true = auto-trading runs regardless of IST market hours
AUTO_TRADING_ENABLED=true

# --- Groww Trade API — the only broker this platform integrates with ---
# ONE of the following auth modes. The access token rotates daily ~6:00 AM IST.
GROWW_ACCESS_TOKEN=              # static token (dev): used verbatim; powers provider=groww + live orders (₹499/mo add-on for market data)
GROWW_API_KEY=                   # auto daily-token generation (POST /v1/token/api/access)
GROWW_API_SECRET=                # + secret → "approval" flow (SHA-256 checksum). Preferred for servers.
GROWW_TOTP_SECRET=               # OR a base32 TOTP secret → "totp" flow (used only if GROWW_API_SECRET is empty)

# --- REAL-MONEY (LIVE) TRADING — keep OFF unless you intend to place REAL orders ---
# A live order requires ALL of: ENABLE_LIVE_TRADING=true, a valid credential for the
# active broker, the user in 'live' mode, the kill switch not tripped, and a per-order
# REAL MONEY confirmation from the client. Unattended (cron) live orders additionally
# require ENABLE_LIVE_AUTO_TRADING=true. Defaults below are deliberately conservative.
ENABLE_LIVE_TRADING=false         # master switch for live order placement (default OFF)
ENABLE_LIVE_AUTO_TRADING=false    # allow the AI auto-trading cron to place LIVE orders (default OFF — strongly recommended)
LIVE_MAX_ORDER_VALUE=5000         # hard ₹ cap per live order (blast-radius limit; applies to manual + auto)

# --- AI MODEL (decision engine — provider is a live per-user toggle, Settings page "AI Provider") ---
# Without a key for the selected provider (or with AI_LLM_ENABLED=false) the AI engine
# falls back to the deterministic Quant scorer alone, so the app runs fully offline.
AI_LLM_ENABLED=true              # master switch for LLM-driven decisions (no effect without a provider API key)

ANTHROPIC_API_KEY=               # required to use Claude as the AI provider
AI_MODEL=claude-opus-4-8         # Claude model id used by the decision engine

# ChatGPT Pro/Plus subscriptions do NOT include API access — this needs a separate
# pay-as-you-go key + billing from platform.openai.com.
OPENAI_API_KEY=                  # required to use OpenAI/GPT as the AI provider
OPENAI_MODEL=gpt-5.4-mini          # OpenAI model id used by the decision engine

# Gemini, Grok, and Perplexity are all called via their OpenAI-compatible endpoints —
# check each provider's docs for the current model id if the default below has moved on
# (these all get retired/renamed faster than most — see constants.js's AI_MODEL_OPTIONS
# for a small curated cheap/balanced/flagship menu per provider, editable live from Settings).
GEMINI_API_KEY=                  # required to use Gemini as the AI provider (aistudio.google.com)
GEMINI_MODEL=gemini-2.5-flash

GROK_API_KEY=                    # required to use Grok as the AI provider (console.x.ai)
GROK_MODEL=grok-4.3

PERPLEXITY_API_KEY=              # required to use Perplexity as the AI provider (perplexity.ai/settings/api)
PERPLEXITY_MODEL=sonar-pro

# --- News (fed into the AI decision engine's context — see newsService.js) ---
# Both live-editable from Settings without a restart.
NEWS_MAX_AGE_HOURS=24             # headlines older than this are filtered out — keeps the AI reading TODAY's news, not week-old evergreen articles
NEWS_HEADLINE_COUNT=3              # stock-specific headlines fetched per decision (2 broad-market headlines are always added on top)
