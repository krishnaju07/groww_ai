PORT=4000
MONGODB_URI=mongodb://localhost:27017/groww_ai
CLIENT_ORIGIN=http://localhost:5173
MARKET_DATA_PROVIDER=yahoo        # yahoo | groww | alphavantage | mock  (default yahoo: free, no key)
ALPHA_VANTAGE_API_KEY=            # required only if provider=alphavantage
IGNORE_MARKET_HOURS=true          # true = auto-trading runs regardless of IST market hours
AUTO_TRADING_ENABLED=true

# --- Broker credentials (used by server/src/services/brokers/*) ---
# Groww auth — ONE of the following. The access token rotates daily ~6:00 AM IST.
GROWW_ACCESS_TOKEN=              # static token (dev): used verbatim; powers provider=groww + live orders (₹499/mo)
GROWW_API_KEY=                   # auto daily-token generation (POST /v1/token/api/access)
GROWW_API_SECRET=                # + secret → "approval" flow (SHA-256 checksum). Preferred for servers.
GROWW_TOTP_SECRET=               # OR a base32 TOTP secret → "totp" flow (used only if GROWW_API_SECRET is empty)

# Zerodha Kite Connect — requires a daily manual login (request_token) via the Brokers page "Reconnect" button.
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Angel One Smart API — TOTP-based session, also re-authenticated daily via "Reconnect".
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# AES-256-GCM key (32 random bytes, base64) used to encrypt stored broker credentials/tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BROKER_CREDENTIAL_KEY=

# --- REAL-MONEY (LIVE) TRADING — keep OFF unless you intend to place REAL orders ---
# A live order requires ALL of: ENABLE_LIVE_TRADING=true, a valid credential for the
# active broker, the user in 'live' mode, the kill switch not tripped, and a per-order
# REAL MONEY confirmation from the client. Unattended (cron) live orders additionally
# require ENABLE_LIVE_AUTO_TRADING=true. Defaults below are deliberately conservative.
ENABLE_LIVE_TRADING=false         # master switch for live order placement (default OFF)
ENABLE_LIVE_AUTO_TRADING=false    # allow the AI auto-trading cron to place LIVE orders (default OFF — strongly recommended)
LIVE_MAX_ORDER_VALUE=5000         # hard ₹ cap per live order (blast-radius limit; applies to manual + auto)

# --- AI MODEL (Claude decision engine) ---
# Without a key (or with AI_LLM_ENABLED=false) the AI engine falls back to the
# deterministic Quant scorer alone, so the app runs fully offline.
ANTHROPIC_API_KEY=               # required to enable Claude-driven decisions
AI_MODEL=claude-opus-4-8         # Claude model id used by the decision engine
AI_LLM_ENABLED=true              # master switch for the Claude model (no effect without ANTHROPIC_API_KEY)
